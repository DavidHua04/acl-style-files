\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Aggregate detection rate for each (ASCII fill mode, model) pair, pooled across resolutions and languages. Rows are ordered by mode (L1--L8); columns are the eight evaluated VLMs. Cell shading runs from red (low detection) to green (high detection). The figure makes visible both the mode-level gradient (L1 and L6 highest, L5 lowest) and the model-level gradient (Gemini-3-Flash and Kimi-K2.5 strongest, Mistral-Small weakest).}}{4}{figure.caption.10}\protected@file@percent }
\newlabel{fig:overall_heatmap}{{1}{4}{Aggregate detection rate for each (ASCII fill mode, model) pair, pooled across resolutions and languages. Rows are ordered by mode (L1--L8); columns are the eight evaluated VLMs. Cell shading runs from red (low detection) to green (high detection). The figure makes visible both the mode-level gradient (L1 and L6 highest, L5 lowest) and the model-level gradient (Gemini-3-Flash and Kimi-K2.5 strongest, Mistral-Small weakest)}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}Findings}{4}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Detection Rates Across Modes and Models}{4}{subsection.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Cochran--Armitage Trend Tests}{4}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Detection rate versus resolution scale for all eight ASCII fill modes, faceted by model. The dashed horizontal line marks the 50\% detection threshold. Detection rates decline sharply with decreasing resolution for most model--mode combinations, but the slope and intercept vary substantially across models and modes.}}{5}{figure.caption.11}\protected@file@percent }
\newlabel{fig:detection_vs_resolution}{{2}{5}{Detection rate versus resolution scale for all eight ASCII fill modes, faceted by model. The dashed horizontal line marks the 50\% detection threshold. Detection rates decline sharply with decreasing resolution for most model--mode combinations, but the slope and intercept vary substantially across models and modes}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Logistic Regression Threshold Estimates}{5}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Cochran--Armitage z-statistics for the resolution--detection trend in each (mode, model) stratum. Blue indicates a significant negative trend (detection declines as resolution decreases); white indicates no trend; red would indicate a positive trend (detection declines as resolution increases). Cells marked ``0\%'' denote strata where the model never detected the content at any resolution, producing zero variance and an undefined z-statistic.}}{5}{figure.caption.12}\protected@file@percent }
\newlabel{fig:cochran_armitage}{{3}{5}{Cochran--Armitage z-statistics for the resolution--detection trend in each (mode, model) stratum. Blue indicates a significant negative trend (detection declines as resolution decreases); white indicates no trend; red would indicate a positive trend (detection declines as resolution increases). Cells marked ``0\%'' denote strata where the model never detected the content at any resolution, producing zero variance and an undefined z-statistic}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Cross-Language Comparison}{6}{subsection.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Logistic regression 50\% detection threshold $\hat  {r}_{0.5}$ for each (mode, model) stratum. $\hat  {r}_{0.5}$ is the resolution above which the model drops below 50\% detection, so higher values indicate stronger detection. White Cells labeled ``0\%'' correspond to strata where detection was zero at every resolution and the logistic fit failed to converge.}}{6}{figure.caption.13}\protected@file@percent }
\newlabel{fig:threshold_heatmap}{{4}{6}{Logistic regression 50\% detection threshold $\hat {r}_{0.5}$ for each (mode, model) stratum. $\hat {r}_{0.5}$ is the resolution above which the model drops below 50\% detection, so higher values indicate stronger detection. White Cells labeled ``0\%'' correspond to strata where detection was zero at every resolution and the logistic fit failed to converge}{figure.caption.13}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Model Origin and Word-Embedded Fill Modes (L5 and L8)}{6}{subsection.4.5}\protected@file@percent }
\citation{bhatia2024globalrg}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Estimated 50\% detection thresholds with 95\% confidence intervals (delta method), faceted by ASCII fill mode. Bars show the point estimate $\hat  {r}_{0.5}$; horizontal lines show CIs. Tight CIs (e.g., Gemini-3-Flash, Kimi-K2.5) reflect strong resolution dependence with abundant transition data; very wide CIs (e.g., Grok-4.1-Fast) reflect strata where resolution is not a meaningful predictor.}}{7}{figure.caption.14}\protected@file@percent }
\newlabel{fig:threshold_errorbars}{{5}{7}{Estimated 50\% detection thresholds with 95\% confidence intervals (delta method), faceted by ASCII fill mode. Bars show the point estimate $\hat {r}_{0.5}$; horizontal lines show CIs. Tight CIs (e.g., Gemini-3-Flash, Kimi-K2.5) reflect strong resolution dependence with abundant transition data; very wide CIs (e.g., Grok-4.1-Fast) reflect strata where resolution is not a meaningful predictor}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.6}Multiple Comparisons Summary}{7}{subsection.4.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces English versus Chinese detection rates by ASCII fill mode and model. Each point represents a (model, mode, resolution) stratum. Points near the diagonal indicate similar detection rates across languages; deviations indicate language-specific performance differences.}}{8}{figure.caption.15}\protected@file@percent }
\newlabel{fig:language_comparison}{{6}{8}{English versus Chinese detection rates by ASCII fill mode and model. Each point represents a (model, mode, resolution) stratum. Points near the diagonal indicate similar detection rates across languages; deviations indicate language-specific performance differences}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces L8 (Chinese characters) detection rate as a function of resolution, with models grouped by origin (Chinese-built: Kimi-K2.5, Qwen3-VL; US/Western-built: the remaining six models). Markers show pooled detection rates within each origin group at each resolution.}}{8}{figure.caption.16}\protected@file@percent }
\newlabel{fig:L8_origin}{{7}{8}{L8 (Chinese characters) detection rate as a function of resolution, with models grouped by origin (Chinese-built: Kimi-K2.5, Qwen3-VL; US/Western-built: the remaining six models). Markers show pooled detection rates within each origin group at each resolution}{figure.caption.16}{}}
